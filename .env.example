DATABASE_URL="postgresql://user:password@localhost:5432/ironbolt"
JWT_SECRET="change-me-to-a-random-secret-that-is-at-least-32-chars"
PORT=3000
CORS_ORIGIN="http://localhost:5173"
NODE_ENV="development"

# Service token for the demo `sample` batch resource. Forks add one
# BATCH_TOKEN_<UPPER_RESOURCE> per resource registered in
# src/batch/register.ts. Generate with `openssl rand -base64 32`.
BATCH_TOKEN_SAMPLE="change-me-to-a-random-secret-for-the-sample-resource"

# Optional. Per-row concurrency cap for batch upserts (src/batch/handler.ts).
# Defaults to 8 when unset; raise for throughput, lower to ease DB pool pressure.
# BATCH_CONCURRENCY=8
